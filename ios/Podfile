# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported

prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'PSGDC' do
  config = use_native_modules!

  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true

 # use_modular_headers!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    targets = installer.pods_project.targets
    targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
        config.build_settings['SWIFT_USE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        
        # Force fmt target to C++17 to avoid C++20 consteval issues (User suggestion)
        if target.name == 'fmt'
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end

        # Fix fmt library consteval error - applied as secondary defense for all targets
        # We use a string for GCC_PREPROCESSOR_DEFINITIONS to be safe with different CocoaPods versions
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        defs = [defs] if defs.is_a?(String)
        unless defs.include?('FMT_USE_CONSTEVAL=0')
          defs << 'FMT_USE_CONSTEVAL=0'
        end
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

        flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
        flags = [flags] if flags.is_a?(String)
        unless flags.include?('-DFMT_USE_CONSTEVAL=0')
          flags << '-DFMT_USE_CONSTEVAL=0'
        end
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = flags
      end
    end

    # Patch CocoaPods readlink issue
    main_target_path = File.join(
      installer.sandbox.target_support_files_root,
      "Pods-PSGDC",
      "Pods-PSGDC-frameworks.sh"
    )

    if File.exist?(main_target_path)
      content = File.read(main_target_path)
      content.gsub!(
        "source=\"$(readlink -f \"${source}\")\"",
        "source=\"$(readlink \"${source}\")\""
      )
      File.write(main_target_path, content)
    end
  end
end